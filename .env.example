# Copy to .env (gitignored). Required for launchd / production (start-service.sh).

SECRET_KEY=

# Optional bind overrides (defaults from config.yaml web.host / web.port)
# HOST=127.0.0.1
# PORT=5503

# Behind Cloudflare tunnel / reverse proxy
# TRUST_PROXY=1
# PRODUCTION=1

# Optional rate-limit backend for multiple gunicorn workers
# RATE_LIMIT_STORAGE_URI=redis://127.0.0.1:6379/0

# --- Authentik OIDC (copy from ../auth/config/clients.yaml after ./install.sh) ---
# OIDC_ENABLED=1
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER=https://auth.svburnttoast.com/application/o/float-plan/
# OIDC_REDIRECT_URI=https://floatplan.svburnttoast.com/oidc/callback
# OIDC_GROUP_ADMINS=boat-admins
# OIDC_GROUP_CREW=boat-crew
# OIDC_GROUP_VIEWERS=boat-viewers
# OIDC_GROUP_PENDING=boat-pending

# Emergency local admin (off by default; see README — Authentik SSO)
# BREAK_GLASS_ENABLED=0
# BREAK_GLASS_USERNAME=breakglass
# BREAK_GLASS_PASSWORD=
